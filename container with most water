#include<vector>
using namespace std;
class Solution {
public:
    int maxArea(vector<int>& height) {
        int n=height.size();
        int i=0;
        int j=n-1;
        int maxwater=0;
        int less;
        while(i<j){
        int less=min(height[i],height[j]);
        int water=less*(j-i);
              if(water>maxwater){
                maxwater=water;
              }
              if(height[i]<height[j]){
              i++;
              }
              else{
                j--;
              }
        } return maxwater;
    }
};
